"""
旅館「Lodgers Bldg SERIE」予約確認エージェント
Google Calendar から今後7日間の予約イベントを取得して表示する
"""

import os
import re
from datetime import datetime, timedelta, timezone

from google.auth.transport.requests import Request
from google.oauth2.credentials import Credentials
from google_auth_oauthlib.flow import InstalledAppFlow
from googleapiclient.discovery import build

# --- 設定 ---
SCOPES = ["https://www.googleapis.com/auth/calendar.readonly"]
CREDENTIALS_FILE = os.path.join(os.path.dirname(__file__), "credentials.json")
TOKEN_FILE = os.path.join(os.path.dirname(__file__), "token.json")

# カレンダーID（Googleカレンダーの設定 > カレンダーの統合 > カレンダーID）
# "primary" はデフォルトのメインカレンダー。予約専用カレンダーがあればそちらに変更してください
CALENDAR_ID = "primary"

# OTA 判定キーワード
OTA_PATTERNS = {
    "Booking.com": [r"booking\.com", r"booking\.com経由", r"booking"],
    "Airbnb":      [r"airbnb", r"エアビー"],
    "VRBO":        [r"vrbo", r"homeaway", r"ホームアウェイ"],
}

JST = timezone(timedelta(hours=9))


# ------------------------------------------------------------------ #
# 認証
# ------------------------------------------------------------------ #

def get_calendar_service():
    creds = None

    if os.path.exists(TOKEN_FILE):
        creds = Credentials.from_authorized_user_file(TOKEN_FILE, SCOPES)

    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
        else:
            if not os.path.exists(CREDENTIALS_FILE):
                raise FileNotFoundError(
                    f"credentials.json が見つかりません: {CREDENTIALS_FILE}\n"
                    "Google Cloud Console から OAuth 2.0 クライアント ID をダウンロードして\n"
                    f"{CREDENTIALS_FILE} に配置してください。"
                )
            flow = InstalledAppFlow.from_client_secrets_file(CREDENTIALS_FILE, SCOPES)
print(f"
